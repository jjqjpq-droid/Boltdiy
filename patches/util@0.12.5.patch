+// Patched shim: the `util` browser polyfill (0.12.5) ships no `util/types`
+// submodule, which breaks Node/server builds (e.g. undici imports it).
+// On the Node.js/Vercel server runtime, re-export the real implementation.
+// This extensionless copy exists because some bundlers request the exact
+// path `util/types` without extension resolution.
+module.exports = require('node:util/types');
